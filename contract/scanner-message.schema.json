{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ars.example/thales-bridge/scanner-message.schema.json",
  "title": "ThalesScannerMessage",
  "description": "Envelope for every WebSocket text frame sent by the Thales scanner bridge (contract v1). See bridge/CONTRACT.md.",
  "oneOf": [
    { "$ref": "#/$defs/statusMessage" },
    { "$ref": "#/$defs/resultMessage" },
    { "$ref": "#/$defs/errorMessage" }
  ],
  "$defs": {
    "statusMessage": {
      "type": "object",
      "required": ["type", "status"],
      "properties": {
        "type": { "const": "status" },
        "status": { "enum": ["idle", "waiting_for_document", "reading"] }
      }
    },
    "resultMessage": {
      "type": "object",
      "required": ["type", "data"],
      "properties": {
        "type": { "const": "result" },
        "data": { "$ref": "#/$defs/documentScanResult" }
      }
    },
    "errorMessage": {
      "type": "object",
      "required": ["type", "code", "message"],
      "properties": {
        "type": { "const": "error" },
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "documentScanResult": {
      "type": "object",
      "required": ["mrz", "images", "capturedAt"],
      "properties": {
        "mrz": { "$ref": "#/$defs/mrzData" },
        "images": { "$ref": "#/$defs/scanImages" },
        "chip": {
          "oneOf": [{ "$ref": "#/$defs/chipData" }, { "type": "null" }]
        },
        "capturedAt": {
          "type": "string",
          "description": "ISO 8601 UTC timestamp assigned by the bridge"
        }
      }
    },
    "mrzData": {
      "type": "object",
      "required": [
        "firstName",
        "lastName",
        "documentNumber",
        "documentType",
        "dateOfBirth",
        "gender",
        "nationality",
        "issuingCountry",
        "expiryDate"
      ],
      "properties": {
        "firstName": { "type": "string" },
        "middleName": { "type": ["string", "null"] },
        "lastName": { "type": "string" },
        "documentNumber": { "type": "string" },
        "documentType": {
          "enum": ["passport", "national_id", "drivers_license", "other"]
        },
        "dateOfBirth": { "$ref": "#/$defs/isoDateOrEmpty" },
        "gender": { "enum": ["M", "F", ""] },
        "nationality": {
          "type": "string",
          "description": "ISO 3166-1 alpha-3 code, or empty string"
        },
        "issuingCountry": {
          "type": "string",
          "description": "ISO 3166-1 alpha-3 code, or empty string"
        },
        "expiryDate": { "$ref": "#/$defs/isoDateOrEmpty" }
      }
    },
    "scanImages": {
      "type": "object",
      "properties": {
        "front": { "$ref": "#/$defs/dataUrlOrNull" },
        "back": { "$ref": "#/$defs/dataUrlOrNull" },
        "portrait": { "$ref": "#/$defs/dataUrlOrNull" }
      }
    },
    "chipData": {
      "type": "object",
      "required": ["present", "verified"],
      "properties": {
        "present": { "type": "boolean" },
        "verified": {
          "type": "boolean",
          "description": "v1 caveat: hard-coded true when chip data arrives — advisory only"
        }
      }
    },
    "isoDateOrEmpty": {
      "type": "string",
      "pattern": "^(\\d{4}-\\d{2}-\\d{2})?$",
      "description": "yyyy-MM-dd, or empty string when unreadable"
    },
    "dataUrlOrNull": {
      "type": ["string", "null"],
      "description": "base64 data URL, e.g. data:image/jpeg;base64,..."
    }
  }
}
